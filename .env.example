# Cloud backup (optional). Without these the app still runs — it just stays local-only.
#
# Both values are safe to ship in the browser bundle: the publishable key grants no access
# on its own, it only lets the client talk to PostgREST. Row-level security is what actually
# protects the data, and every table has it enabled. NEVER put the `service_role`/secret key
# here — it bypasses RLS entirely and this file's values end up in the JS bundle.
#
# Copy to .env.local (git-ignored) and fill in from Supabase → Project Settings → API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxx
